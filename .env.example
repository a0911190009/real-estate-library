# 複製到專案根目錄並改名為 .env，或把以下變數加入 ~/Projects/.env
# 本服務需與 Portal 共用 FLASK_SECRET_KEY，並由 Portal 設定 LIBRARY_URL。

PORT=5004
FLASK_DEBUG=1
FLASK_SECRET_KEY=與 Portal 相同的密鑰
PORTAL_URL=https://real-estate-portal-334765337861.asia-east1.run.app

# 部署後請在 ~/Projects/.env 加上（把網址改成實際 Cloud Run 網址）：
# LIBRARY_URL=https://real-estate-library-334765337861.asia-east1.run.app
# FREE_LIBRARY_LIMIT=3
